    {"name": "icp_gate_qualified", "type": "formula", "source": "clayscript", "cost_credits": 0, "depends_on": [], "run_condition": null, "config": {}, "formula_text": "{{ICP_GATE_FORMULA}}", "claygent_prompt": null, "notes": "Global Rule 1: gate before paid columns"},
    {"name": "email_dropcontact", "type": "enrichment", "source": "dropcontact", "cost_credits": 2, "depends_on": ["icp_gate_qualified"], "run_condition": "icp_gate_qualified = TRUE", "config": {"provider_key": "dropcontact"}, "formula_text": null, "claygent_prompt": null, "notes": "Strongest EU match rate; GDPR-compliant"},
