    {"name": "email", "type": "formula", "source": "clayscript", "cost_credits": 0, "depends_on": ["email_dropcontact", "email_datagma", "email_findymail"], "run_condition": null, "config": {}, "formula_text": "COALESCE(email_dropcontact, email_datagma, email_findymail)", "claygent_prompt": null, "notes": null},
    {"name": "email_source", "type": "formula", "source": "clayscript", "cost_credits": 0, "depends_on": ["email_dropcontact", "email_datagma", "email_findymail"], "run_condition": null, "config": {}, "formula_text": "IF(email_dropcontact IS NOT NULL, \"dropcontact\", IF(email_datagma IS NOT NULL, \"datagma\", IF(email_findymail IS NOT NULL, \"findymail\", NULL)))", "claygent_prompt": null, "notes": null},
    {"name": "email_verified", "type": "enrichment", "source": "zerobounce", "cost_credits": 1, "depends_on": ["email"], "run_condition": "email IS NOT NULL", "config": {"provider_key": "zerobounce"}, "formula_text": null, "claygent_prompt": null, "notes": "EU providers don't ship verified-by-default — verify all"},
    {"name": "email_deliverable", "type": "formula", "source": "clayscript", "cost_credits": 0, "depends_on": ["email_verified"], "run_condition": null, "config": {}, "formula_text": "email_verified IN [\"valid\", \"accept_all_high\"]", "claygent_prompt": null, "notes": null}
